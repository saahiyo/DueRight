# --- DueRight backend config (example — copy to .env and fill in) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
FRONTEND_ORIGIN=*

# Firebase service account credential (JSON string encoded in base64)
FIREBASE_SERVICE_ACCOUNT=your_base64_encoded_firebase_creds_here
FIREBASE_DATABASE_URL=https://your-firebase-project-default-rtdb.firebaseio.com
